def draw_frame(T, ax, label='Frame'):
    origin = np.array(T[:3, 3]).astype(np.float64).ravel()
    R      = np.array(T[:3, :3]).astype(np.float64)
    ax.quiver(*origin, *R[:,0], color='r', arrow_length_ratio=0.1, label=f'{label} X')
    ax.quiver(*origin, *R[:,1], color='g', arrow_length_ratio=0.1, label=f'{label} Y')
    ax.quiver(*origin, *R[:,2], color='b', arrow_length_ratio=0.1, label=f'{label} Z')
    ax.text(*origin, f'{label} Origin', fontsize=10, color='k')


