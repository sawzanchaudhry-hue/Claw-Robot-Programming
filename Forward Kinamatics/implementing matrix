# Part 3(3) — Single-joint sweep


def T_link(th, d, a, al):
    ct, st = math.cos(th), math.sin(th)
    ca, sa = math.cos(al), math.sin(al)
    return np.array([
        [ct, -st*ca,  st*sa, a*ct],
        [st,  ct*ca, -ct*sa, a*st],
        [0,      sa,     ca,    d],
        [0,       0,      0,    1]
    ], dtype=float)


def ned2_fk(q):
    q1,q2,q3,q4,q5,q6 = q
    th1 = q1
    th2 = q2 + math.pi/2
    th3 = q3
    th4 = q4 + math.pi
    th5 = -q5
    th6 = q6 + math.pi/2
    d1,d2,d3,d4,d5,d6 = 0.183, 0.0, 0.0, 0.235, 0.0, 0.06
    a1,a2,a3,a4,a5,a6 = 0.0,   0.221, 0.0282, 0.0,  0.0,  0.035
    a1p,a2p,a3p,a4p,a5p,a6p = math.pi/2, 0.0, math.pi/2, -math.pi/2, math.pi/2, 0.0


    T10 = T_link(th1,d1,a1,a1p)
    T21 = T_link(th2,d2,a2,a2p)
    T32 = T_link(th3,d3,a3,a3p)
    T43 = T_link(th4,d4,a4,a4p)
    T54 = T_link(th5,d5,a5,a5p)
    T65 = T_link(th6,d6,a6,a6p)
    T60 = (((T10 @ T21) @ T32) @ T43) @ (T54 @ T65)


    R = T60[:3,:3]; p = T60[:3,3]
    yaw   = math.atan2(R[1,0], R[0,0])
    pitch = math.atan2(-R[2,0], math.hypot(R[2,1], R[2,2]))
    roll  = math.atan2(R[2,1], R[2,2])
    return p, (roll, pitch, yaw), T60


# Baseline and sweep settings
q0    = np.array([-0.2, 0.3, 0.2, 0.3, -0.6, 0.0])
j     = 2          # sweep index
delta = 0.05
n     = 15
