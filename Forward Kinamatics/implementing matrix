pred_pts = []
pred_orient = []
for k in kvals:
    qk = q0.copy()
    qk[j] = q0[j] + k*delta
    p, rpy, _ = ned2_fk(qk)
    pred_pts.append(p)
    pred_orient.append(rpy)
pred_pts = np.array(pred_pts)


