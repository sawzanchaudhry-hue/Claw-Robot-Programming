# RPY extraction (ZYX)
def rpy_from_R(R):
    roll  = sy.atan2(R[2,1], R[2,2])
    pitch = sy.atan2(-R[2,0], sy.sqrt(R[2,1]**2 + R[2,2]**2))
    yaw   = sy.atan2(R[1,0], R[0,0])
    return roll, pitch, yaw


