# DH transform helper
def dh_T(th, d, a, al):
    return Matrix([
        [cos(th), -sin(th)*cos(al),  sin(th)*sin(al), a*cos(th)],
        [sin(th),  cos(th)*cos(al), -cos(th)*sin(al), a*sin(th)],
        [0,        sin(al),          cos(al),         d],
        [0,        0,                0,               1]
    ])


# SCARA FK
def scara_fk(theta_list, d_list, a_list, alpha_list):
    A01 = dh_T(theta_list[0], d_list[0], a_list[0], alpha_list[0])
    A12 = dh_T(theta_list[1], d_list[1], a_list[1], alpha_list[1])
    A23 = dh_T(theta_list[2], d_list[2], a_list[2], alpha_list[2])
    A34 = dh_T(theta_list[3], d_list[3], a_list[3], alpha_list[3])
    T04 = simplify(A01 * A12 * A23 * A34)
    pos = T04[:3, 3]
    R   = T04[:3, :3]
    return T04, pos, R


