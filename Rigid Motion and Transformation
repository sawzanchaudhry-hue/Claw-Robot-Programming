import sympy as sp
import numpy as np


# A1) Symbols and basic rotation matrices
# Lab notation: roll = phi (about x), pitch = alpha (about y), yaw = theta (about z)
phi, alpha, theta = sp.symbols('phi alpha theta', real=True) # crate symols and tells sympy they are real


#define basic rotation matrices
def Rx(phi):
    return sp.Matrix([
        [1,            0,             0],
        [0,  sp.cos(phi), -sp.sin(phi)],
        [0,  sp.sin(phi),  sp.cos(phi)]
    ])


def Ry(alpha):
    return sp.Matrix([
        [ sp.cos(alpha), 0,  sp.sin(alpha)],
        [ 0,             1,  0],
        [-sp.sin(alpha), 0,  sp.cos(alpha)]
    ])


def Rz(theta):
    return sp.Matrix([
        [sp.cos(theta), -sp.sin(theta), 0],
        [sp.sin(theta),  sp.cos(theta), 0],
        [0,              0,             1]
    ])


# Composite orientation (extrinsic XYZ; roll→pitch→yaw)
R_xyz = Rx(phi) * Ry(alpha) * Rz(theta)


print("A1) Rotation matrices:")
sp.pprint(sp.Matrix(Rx(phi)))
sp.pprint(sp.Matrix(Ry(alpha)))
sp.pprint(sp.Matrix(Rz(theta)))
print("\nComposite R = Rx(phi) * Ry(alpha) * Rz(theta):")
sp.pprint(sp.simplify(R_xyz))


# A2) NumPy verification of Rx identities (NUMERIC)


def Rx_np(a):
    c, s = np.cos(a), np.sin(a)
    return np.array([[1, 0, 0],
                     [0, c,-s],
                     [0, s, c]], dtype=float)




# Creates a random number generator with a given seed for reproducibility
def check_rx_identities_numpy(num_trials=10, tol=1e-12, seed=0):
    rng = np.random.default_rng(seed) # random number generator that is the same each time
    I = np.eye(3) # 3x3 indentity matrix


    # (a) Rx(a) Rx(b) = Rx(a+b)
    # test for num_trials random pairs (a,b)
    for _ in range(num_trials):
        a, b = rng.uniform(-np.pi, np.pi, size=2) # random angles in radians
        lhs = Rx_np(a) @ Rx_np(b) # matrix multiply
        rhs = Rx_np(a + b) # rotation by (a+b)
        if not np.allclose(lhs, rhs, atol=tol): #check if close within tolerance
            raise AssertionError("A2(a) failed for some a,b")
    # (b) Rx(a) Rx(-a) = I
    for _ in range(num_trials): # test for num_trials random angles
        a = rng.uniform(-np.pi, np.pi) # random angles between -pi and pi
        lhs = Rx_np(a) @ Rx_np(-a) # matric multiply
        if not np.allclose(lhs, I, atol=tol):
            raise AssertionError("A2(b) failed for some a")
    print("A2) true = NumPy checks passed: Rx(a)Rx(b)=Rx(a+b) and Rx(a)Rx(-a)=I")


check_rx_identities_numpy()




# A3) Generic homogeneous transform  T_i^{i-1}
# Position variables in metres:
x, y, z = sp.symbols('x y z', real=True)




def Ti_im1(x, y, z, phi, alpha, theta):
    """
    Homogeneous transform from frame i-1 to frame i
    given translation (x,y,z) and orientation (roll=pitch=yaw=0)
    """
    R = Rx(phi) * Ry(alpha) * Rz(theta) # computes rotation r
    T = sp.eye(4) #4x4 identity matrix
    T[:3, :3] = R # replace top-left 3x3 with R
    T[:3,  3] = sp.Matrix([x, y, z]) # insert translation vector in the last column
    return sp.simplify(T)


T_sym = Ti_im1(x, y, z, phi, alpha, theta)
print("\nA3) Generic homogeneous transform  T_i^{i-1}:")
sp.pprint(T_sym)


