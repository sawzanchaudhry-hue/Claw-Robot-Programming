def rotz(deg):
    t = np.deg2rad(deg)
    c, s = np.cos(t), np.sin(t)
    T = np.eye(4); T[0,0]=c; T[0,1]=-s; T[1,0]=s; T[1,1]=c
    return T


def trans(x=0, y=0, z=0):
    T = np.eye(4); T[:3,3] = [x, y, z]; return T


def pose_point(H):
    return H[:3,3].copy()


def print_pose(name, H):
    p = pose_point(H)
    print(f"{name:>6s} position (cm): [{p[0]:8.4f}, {p[1]:8.4f}, {p[2]:8.4f}]")


# in cm and degrees
L_OF_OE   = 50.0          # OF -> OE: +X 50
L_OE_OD_x = 50.0          # OE -> OD: +X 50
L_OE_OD_z = 40.0          # OE -> OD: +Z 40
ELBOW_Z   = +60.0         # rotation at OD: +60° about local Z (left)
L_OD_OC   = 60.0          # OD -> OC: +X 60
L_OC_OB_z = 50.0          # OC -> OB: +Z 50
WRIST_Z   = -46.0         # rotation at OB: -46° about local Z (right)
L_OB_A    = 40.0          # OB -> A: +X 40 (tool length)


# build the chain of transformations
H0 = np.eye(4)


# OF -> OE
H0E = H0 @ trans(x=L_OF_OE)


# OE -> OD (no rotation yet)
H0D = H0E @ trans(x=L_OE_OD_x, z=L_OE_OD_z)


# At OD: rotate +60° about local Z
H0Drot = H0D @ rotz(ELBOW_Z)


# OD -> OC along the rotated x by 60 cm
H0C = H0Drot @ trans(x=L_OD_OC)


# OC -> OB +Z 50
