# d) another random 6x6; dims, per-column min/max values and positions; zero row2 col2..5
arbitrary_int = np.random.randint(1, 10, size=(6, 6)) # random 6x6 integers 1-9
dims = arbitrary_int.shape # (rows, cols)
col_max_vals = arbitrary_int.max(axis=0) # max of each colmn (axis=0 -> go down each colmn)
