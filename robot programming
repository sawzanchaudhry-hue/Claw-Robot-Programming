# a) random A, B; ensure invertible before inv()
def rand_invertible(n=6, low=1, high=10): # random invertible nxn matrix M with intergers between 1-9
    while True:
        M = np.random.randint(low, high, size=(n, n)) # random nxn matrix
        if abs(np.linalg.det(M)) > 1e-8: # check if invertible (det does not = 0) threshold close to o 1e^-8
            return M


A = rand_invertible() #random invertible 6x6 metrix
B = rand_invertible()
print("Matrix A:\n", A)
print("Matrix B:\n", B)


# b) inverses and matrix product
A_inv = np.linalg.inv(A) # compute inverse of A
B_inv = np.linalg.inv(B)
AB = A @ B # multiply A and B
print("\nInverse of A:\n", A_inv)
print("Inverse of B:\n", B_inv)
print("A @ B:\n", AB)


# (optional extras often asked)
print("det(A) =", np.linalg.det(A)) # print determinant of A
print("det(B) =", np.linalg.det(B))
print("A^T:\n", A.T) # transpose of A
print("B^T:\n", B.T)


